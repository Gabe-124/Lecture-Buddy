# Required for server-side Convex calls
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Shared bearer key used by Pi-facing API routes (/api/v1/**)
UPLOAD_API_KEY=replace-with-pi-upload-key

# Dashboard-only control key required for each control action
DASHBOARD_CONTROL_API_KEY=replace-with-dashboard-control-key

# Used by /api/control/reprocess and /api/control/commands for explicit operator actions.
