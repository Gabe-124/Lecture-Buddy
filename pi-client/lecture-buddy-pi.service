[Unit]
Description=Lecture Buddy Raspberry Pi Client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/lecture-buddy/pi-client
EnvironmentFile=/opt/lecture-buddy/pi-client/.env
ExecStart=/opt/lecture-buddy/pi-client/run.sh
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
