# Local secrets and device config for the Raspberry Pi client.
# Keep the real .env file on the Pi only. Do not commit it.

LECTURE_BUDDY_DEVICE_ID=pi-classroom-01
LECTURE_BUDDY_CLASSROOM_LABEL=room-101
SESSION_TITLE_PREFIX=Class Session
HEARTBEAT_SECONDS=1.0
STRICT_DEVICE_CHECKS=false

# Directory layout on the Pi.
LECTURE_BUDDY_DATA_DIR=./data
LECTURE_BUDDY_CACHE_DIR=./cache
LECTURE_BUDDY_LOGS_DIR=./logs
LECTURE_BUDDY_QUEUE_DIR=./queue

# Cloud and upload placeholders.
CLOUD_API_BASE_URL=https://your-cloud.example
UPLOAD_INGEST_URL=https://your-cloud.example/api/pi-ingest
UPLOAD_API_KEY=replace-with-local-secret
UPLOADTHING_APP_ID=replace-if-needed
UPLOADTHING_TOKEN=replace-if-needed
UPLOAD_TIMEOUT_SECONDS=20
UPLOAD_BATCH_SIZE=4
UPLOAD_VERIFY_TLS=true
KEEP_UPLOADED_FILES=false

# Audio capture.
AUDIO_CHUNK_SECONDS=15
AUDIO_SAMPLE_RATE_HZ=16000
AUDIO_CHANNELS=1
AUDIO_INPUT_DEVICE=

# Camera capture.
CAMERA_DEVICE_INDEX=0
CAMERA_WARMUP_SECONDS=0.25
CAMERA_FRAME_WIDTH=1280
CAMERA_FRAME_HEIGHT=720
IMAGE_CAPTURE_INTERVAL_SECONDS=12
IMAGE_JPEG_QUALITY=92
IMAGE_MIN_DIFF_SCORE=0.12
IMAGE_MIN_BLUR_SCORE=85.0
IMAGE_MIN_QUALITY_SCORE=0.45

# Local heuristic cue phrases. Real transcript guidance happens in the cloud later.
TRANSCRIPT_CUE_PHRASES=as you can see,this diagram,write this down,on the board

LOG_LEVEL=INFO
